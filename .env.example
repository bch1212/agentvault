# Database (Railway Postgres or Supabase)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/agentvault

# Encryption key for credential values (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VAULT_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
