{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.bch1212/agentvault",
  "description": "Credential vault for AI agents — Fernet-encrypted keys, per-agent budgets, audit logs.",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/bch1212/agentvault",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "agentvault-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AGENTVAULT_API_URL",
          "description": "Base URL of your AgentVault deployment",
          "isRequired": true,
          "default": "https://agentvault-api-production.up.railway.app"
        },
        {
          "name": "AGENTVAULT_AGENT_KEY",
          "description": "Your avk_ agent API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
